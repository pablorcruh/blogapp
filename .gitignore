*.jks
*.keystore
keystore.properties
signing.properties
release-keystore.jks
upload-keystore.jks

# Google Services (contains API keys — keep out of VCS)
google-services.json
GoogleService-Info.plist

# External native build
.externalNativeBuild/
.cxx/

# NDK
*.so
obj/

# Kotlin / kapt generated
**/build/generated/

